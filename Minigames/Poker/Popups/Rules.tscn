[node name="Label2" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=786125093]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "Santa Rose Poker is a game of cards. You bet money to win the entire bid. The highest hand wins. Players' hand is calculated from the two cards in the players' hand and from the shared cards on the table."
autowrap_mode = 2

[node name="Label3" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=765215949]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "The game flow:"
autowrap_mode = 2

[node name="Label4" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=2023774358]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "1. Every player gets two cards, and three cards are dealt on the table"
autowrap_mode = 2

[node name="Label5" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=1533265663]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "2. Players decide if they want to bid money, pass, or fold"
autowrap_mode = 2

[node name="Label6" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=1552706462]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "3. If a player raises the bid, all players must raise the bid again, call the bid, or fold"
autowrap_mode = 2

[node name="Label7" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=1023633119]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "4. Once all players pass, call, or fold, a new card is dealt on the table"
autowrap_mode = 2

[node name="Label8" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=674271624]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "5. Players can bid again"
autowrap_mode = 2

[node name="Label9" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=1754723905]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "6. One more card is dealt on the table"
autowrap_mode = 2

[node name="Label10" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=147194263]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "7. Players can bid one last time"
autowrap_mode = 2

[node name="Label11" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer2/ScrollContainer/VBoxContainer" unique_id=1964349705]
custom_minimum_size = Vector2(1, 0)
layout_mode = 2
text = "8. After the bidding is done, cards are revealed, and the highest hand wins"
autowrap_mode = 2

